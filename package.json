{
  "name": "my-app",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "prebuild": "npm --prefix ../askr-lucide run build",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "type-check": "tsc --noEmit",
    "lint": "vp lint src tests",
    "lint:fix": "vp lint --fix src tests",
    "fmt": "vp fmt \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"*.md\""
  },
  "dependencies": {
    "@askrjs/askr": ">=0.0.30 <0.1.0",
    "@askrjs/charts": "file:../askr-charts",
    "@askrjs/ui": "0.0.1",
    "@askrjs/themes": "file:../askr-themes",
    "@askrjs/lucide": "file:../askr-lucide"
  },
  "devDependencies": {
    "@askrjs/vite": "0.0.1",
    "@types/node": "^25.6.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  }
}
