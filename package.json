{
  "name": "my-app",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "npm run test:unit && npm run test.jsdom && npm run test.browser",
    "test:unit": "vp test run -c vitest.test.unit.config.ts",
    "test.jsdom": "vp test run -c vitest.test.jsdom.config.ts",
    "test.browser": "vp test run -c vitest.test.browser.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "vp lint .",
    "lint:fix": "vp lint --fix src tests",
    "fmt": "vp fmt ."
  },
  "packageManager": "npm@11.14.1",
  "dependencies": {
    "@askrjs/askr": "0.0.37",
    "@askrjs/charts": "0.0.1",
    "@askrjs/lucide": "0.0.1",
    "@askrjs/themes": "file:../askr-themes",
    "@askrjs/ui": "0.0.7",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@askrjs/vite": "0.0.2",
    "@types/node": "^25.9.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.21"
  }
}
